{
    "title": "Development Documents for Entertech Affetive Cloud",
    "author": "Entertech",
    "description": "The affective cloud platform is based on EEG, combined with multi-dimensional sensors such as heart rate, to achieve monitoring of human health and identification of states such as attention, relaxation and pressure.",
    "language": "en",
    "gitbook": "3.2.3",
    "plugins": [
        "-sharing",
        "-lunr", 
        "-search", 
        "-fontsettings",
        "theme-fexa",
        "anchors",
        "image-captions",
        "back-to-top-button",
        "cuav-chapters",
        "code",
        "search-pro",
        "advanced-emoji",
        "emphasize",
        "splitter",
        "tbfed-pagefooter",
        "klipse",
        "flexible-alerts",
        "auto-scroll-table",
        "lightbox",
        "image-div"
    ],
    "variables": {
        "themeFexa":{
            "nav":[
                {
                    "url":"https://www.entertech.cn/en/home.html",
                    "target":"_blank",
                    "name": "Entertech Website"
                },
                {
                    "url":"https://github.com/Entertech/Enter-AffectiveCloud-Demo-Android",
                    "target":"_blank",
                    "name": "Android Demo"
                },
                {
                    "url":"https://github.com/Entertech/Enter-AffectiveCloud-Demo-iOS",
                    "target":"_blank",
                    "name": "iOS Demo"
                },
                {
                    "url":"https://github.com/Entertech/Enter-Biomodule-BLE-iOS-SDK",
                    "target":"_blank",
                    "name": "iOS Device SDK"
                },
                {
                    "url":"https://github.com/Entertech/Enter-Biomodule-BLE-Android-SDK",
                    "target":"_blank",
                    "name": "Android Device SDK"
                }
            ]
        }
    },
    "pluginsConfig": {
        "code": {
            "copyButtons": true
        },
        "flexible-alerts": {
            "style": "flat",
            "note": {
                "label": "Note"
            },
            "tip": {
                "label": "Tips"
            },
            "warning": {
                "label": "Warning"
            },
            "danger": {
                "label": "Danger"
            }
        },
        "theme-fexa":{
            "search-placeholder":"Input keywords",
            "logo":"./logo.png",
            "favicon": "./favicon.png"
        },
        "tbfed-pagefooter": {
            "copyright":"© Entertech 2021",
            "modify_label": "Modified time：",
            "modify_format": "YYYY-MM-DD HH:mm:ss"
        }
    },
    "styles": {
        "website": "styles/website.css"
    }
}
